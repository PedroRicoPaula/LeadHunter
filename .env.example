# Só necessário se usares o LLM Anthropic (provider: anthropic em settings.yaml)
ANTHROPIC_API_KEY=coloca_aqui

# NVIDIA NIM — LLM, Reranking, Embeddings, Vision (build.nvidia.com)
# Uma chave serve todos os modelos NIM. Free tier disponível.
NVIDIA_API_KEY=nvapi-coloca_aqui

# Opcional — só para scripts/01_discovery.py (versão paga com Google Places API)
# O sistema usa OpenStreetMap por defeito, sem chave.
GOOGLE_PLACES_API_KEY=opcional
